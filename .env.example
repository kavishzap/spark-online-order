# Or: VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon public key (safe in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpsZXdsdXlmeXZrbGViYW9jY2tlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjA3NjQ3NDgsImV4cCI6MjA3NjM0MDc0OH0.jtA749wT08aqe4MLZjZWBjPjGhnKcH8Z-nE0aOs8tWQ
# Or: VITE_SUPABASE_ANON_KEY=

# service_role key — SERVER ONLY (/api/orders, /api/products). Never commit real values.
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpsZXdsdXlmeXZrbGViYW9jY2tlIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2MDc2NDc0OCwiZXhwIjoyMDc2MzQwNzQ4fQ.UGJqdOUDZgOsCLABTXSJYyFARkoDYo7zoDLv_s_J1eQ
# Or: SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# WhatsApp checkout handoff (required)
# -----------------------------------------------------------------------------
# SodaMax BOT number for "Continue on WhatsApp" after checkout (digits only, no +)
# Example: 23057833020 — NOT the support/human number unless they are the same
VITE_SODAMAX_BOT_WHATSAPP_NUMBER=23052551145

# Signed store session (?s= in URL) — MUST match whatsappbot exactly
# SODAMAX_CHECKOUT_SESSION_SECRET=
#
# How to generate (run once on your machine, copy output to BOTH apps):
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Set the same value in:
#   whatsappbot/.env.local  (or Netlify env for whatsappbot site)
#   sodamax_order_platform/.env  (or Netlify env for store site)
